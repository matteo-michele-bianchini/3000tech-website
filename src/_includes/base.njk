{% set t = en if lang == "en" else it %}<!DOCTYPE html>
<html lang="{{ t.htmlLang }}">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{{ t.meta.description }}">
    <meta name="keywords" content="{{ t.meta.keywords }}">
    <meta name="author" content="Matteo Michele Bianchini">
    <meta name="robots" content="index, follow">
    <meta property="og:title" content="{{ t.meta.ogTitle }}">
    <meta property="og:description" content="{{ t.meta.ogDescription }}">
    <meta property="og:type" content="website">
    <meta property="og:locale" content="{{ t.meta.ogLocale }}">
    <meta property="og:url" content="{{ t.meta.ogUrl }}">
    <meta property="og:image" content="{{ site.ogImage }}">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <link rel="alternate" hreflang="it" href="https://3000tech.it/">
    <link rel="alternate" hreflang="en" href="https://3000tech.it/en/">
    <link rel="alternate" hreflang="x-default" href="https://3000tech.it/">
    <link rel="canonical" href="{{ t.meta.canonical }}">
    <title>{{ t.meta.title }}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <!-- Apply theme class before paint to avoid FOUC -->
    <script>
        (function () {
            try {
                var stored = localStorage.getItem('theme');
                var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
                var dark = stored === 'dark' || (stored === null && prefersDark);
                if (dark) document.documentElement.classList.add('dark');
            } catch (e) {}
        })();
    </script>
    <link rel="stylesheet" href="/css/styles.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: '#1e40af',
                        secondary: '#3b82f6',
                        accent: '#60a5fa'
                    }
                }
            }
        }
    </script>
</head>

<body class="bg-gray-50 text-gray-800 dark:bg-slate-950 dark:text-slate-100">
    {% set navItems = [
        { label: t.nav.portfolio, href: t.anchors.portfolio },
        { label: t.nav.about, href: t.anchors.about },
        { label: t.nav.team, href: t.anchors.team },
        { label: t.nav.services, href: t.anchors.services },
        { label: t.nav.tech, href: t.anchors.tech },
        { label: t.nav.contact, href: t.anchors.contact }
    ] %}
    <!-- Navigation -->
    <nav class="fixed w-full bg-white/95 dark:bg-slate-900/95 backdrop-blur-sm shadow-sm dark:shadow-black/30 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <div class="flex-shrink-0">
                    <a href="#" class="flex items-center gap-2 text-lg font-bold text-primary dark:text-accent">
                        <img src="/favicon.svg" alt="Logo" class="w-8 h-8">
                        3000Tech
                    </a>
                </div>
                <div class="hidden lg:block">
                    <div class="ml-10 flex items-baseline space-x-8">
                        {% for item in navItems %}
                        <a href="#{{ item.href }}" class="text-gray-600 dark:text-slate-300 hover:text-primary dark:hover:text-accent transition-colors">{{ item.label }}</a>
                        {% endfor %}
                        <button id="theme-toggle" class="text-gray-600 dark:text-slate-300 hover:text-primary dark:hover:text-accent transition-colors p-1" aria-label="{{ t.nav.themeToggleLabel }}" title="{{ t.nav.themeToggleLabel }}">
                            <i class="fas fa-moon theme-icon-dark"></i>
                            <i class="fas fa-sun theme-icon-light hidden"></i>
                        </button>
                        <div class="flex items-center border-l border-gray-200 dark:border-slate-700 pl-6 ml-2 gap-2">
                            {% if lang == "en" %}
                            <a href="/" class="opacity-50 hover:opacity-100 transition-opacity">
                                <img src="https://flagcdn.com/w40/it.png" alt="Italiano" class="w-6 h-4 object-cover rounded-sm">
                            </a>
                            <span class="text-gray-300 dark:text-slate-600">|</span>
                            <img src="https://flagcdn.com/w40/gb.png" alt="English" class="w-6 h-4 object-cover rounded-sm ring-2 ring-primary">
                            {% else %}
                            <img src="https://flagcdn.com/w40/it.png" alt="Italiano" class="w-6 h-4 object-cover rounded-sm ring-2 ring-primary">
                            <span class="text-gray-300 dark:text-slate-600">|</span>
                            <a href="/en/" class="opacity-50 hover:opacity-100 transition-opacity">
                                <img src="https://flagcdn.com/w40/gb.png" alt="English" class="w-6 h-4 object-cover rounded-sm">
                            </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
                <button id="mobile-menu-btn" class="lg:hidden p-2">
                    <i class="fas fa-bars text-gray-600 dark:text-slate-300"></i>
                </button>
            </div>
        </div>
        <!-- Mobile menu -->
        <div id="mobile-menu" class="hidden lg:hidden bg-white dark:bg-slate-900 border-t border-gray-200 dark:border-slate-700">
            <div class="px-4 py-3 space-y-3">
                {% for item in navItems %}
                <a href="#{{ item.href }}" class="block text-gray-600 dark:text-slate-300 hover:text-primary dark:hover:text-accent">{{ item.label }}</a>
                {% endfor %}
                <button id="theme-toggle-mobile" class="flex items-center gap-2 text-gray-600 dark:text-slate-300 hover:text-primary dark:hover:text-accent transition-colors w-full text-left">
                    <i class="fas fa-moon theme-icon-dark w-4"></i>
                    <i class="fas fa-sun theme-icon-light hidden w-4"></i>
                    <span class="theme-label-dark">{{ t.nav.themeDark }}</span>
                    <span class="theme-label-light hidden">{{ t.nav.themeLight }}</span>
                </button>
                <div class="flex items-center gap-4 pt-3 border-t border-gray-200 dark:border-slate-700 mt-3">
                    {% if lang == "en" %}
                    <a href="/" class="flex items-center gap-2 text-gray-400 dark:text-slate-500 hover:text-primary dark:hover:text-accent transition-colors">
                        <img src="https://flagcdn.com/w40/it.png" alt="IT" class="w-6 h-4 object-cover rounded-sm opacity-50"> IT
                    </a>
                    <span class="flex items-center gap-2 text-primary dark:text-accent font-medium">
                        <img src="https://flagcdn.com/w40/gb.png" alt="EN" class="w-6 h-4 object-cover rounded-sm"> EN
                    </span>
                    {% else %}
                    <span class="flex items-center gap-2 text-primary dark:text-accent font-medium">
                        <img src="https://flagcdn.com/w40/it.png" alt="IT" class="w-6 h-4 object-cover rounded-sm"> IT
                    </span>
                    <a href="/en/" class="flex items-center gap-2 text-gray-400 dark:text-slate-500 hover:text-primary dark:hover:text-accent transition-colors">
                        <img src="https://flagcdn.com/w40/gb.png" alt="EN" class="w-6 h-4 object-cover rounded-sm opacity-50"> EN
                    </a>
                    {% endif %}
                </div>
            </div>
        </div>
    </nav>

    {{ content | safe }}

    <!-- Footer -->
    <footer class="bg-gray-900 dark:bg-slate-950 text-gray-400 dark:text-slate-500 py-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-col md:flex-row justify-between items-center">
                <div class="mb-4 md:mb-0">
                    <div class="flex items-center gap-2 mb-1">
                        <img src="/favicon.svg" alt="Logo" class="w-8 h-8">
                        <p class="text-lg font-semibold text-white">3000Tech</p>
                    </div>
                    <p class="text-sm">{{ t.footer.owner }}</p>
                    <p class="text-sm">{{ t.footer.legal }}</p>
                    <p class="text-sm">{{ t.footer.vat }}</p>
                </div>
                <div class="flex space-x-6">
                    <a href="mailto:{{ site.email }}" class="hover:text-white transition-colors">
                        <i class="fas fa-envelope text-xl"></i>
                    </a>
                    <a href="tel:{{ site.phone }}" class="hover:text-white transition-colors">
                        <i class="fas fa-phone text-xl"></i>
                    </a>
                    <a href="{{ site.linkedin }}" target="_blank"
                        rel="noopener noreferrer" class="hover:text-white transition-colors">
                        <i class="fab fa-linkedin-in text-xl"></i>
                    </a>
                    <a href="{{ site.github }}" target="_blank" rel="noopener noreferrer"
                        class="hover:text-white transition-colors">
                        <i class="fab fa-github text-xl"></i>
                    </a>
                </div>
            </div>
            <div class="border-t border-gray-800 mt-8 pt-8 text-center text-sm">
                <p>{{ t.footer.copyright }}</p>
            </div>
        </div>
    </footer>

    <div id="client-overlay" class="fixed inset-0 z-50 flex items-center justify-center pointer-events-none" style="opacity:0;transition:opacity 0.3s ease;">
        <div class="absolute inset-0 bg-black/40"></div>
        <div id="overlay-card" class="relative bg-white dark:bg-slate-800 rounded-2xl shadow-2xl px-8 py-6 max-w-xs text-center" style="transform:scale(0.92) translateY(8px);transition:transform 0.35s cubic-bezier(0.16,1,0.3,1);">
            <p id="overlay-name" class="text-lg font-bold text-gray-900 dark:text-slate-100"></p>
            <div class="w-8 h-0.5 bg-blue-600 mx-auto my-3"></div>
            <p id="overlay-desc" class="text-gray-600 dark:text-slate-300 text-sm"></p>
        </div>
    </div>
    <script src="/js/main.js"></script>
    </body>

</html>
